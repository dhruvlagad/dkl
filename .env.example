# ============================================
# GitHub OAuth Configuration
# ============================================
# Create a GitHub OAuth App at: https://github.com/settings/developers
# 1. Go to https://github.com/settings/developers → OAuth Apps → New OAuth App
# 2. Fill in:
#    - Application name: "DKL Portfolio Admin"
#    - Homepage URL: https://dhruvlagad.github.io/dkl/
#    - Authorization callback URL: https://YOUR_RENDER_URL/auth/github/callback
# 3. Copy Client ID and Client Secret below

GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_CALLBACK_URL=https://your-render-app-name.onrender.com/auth/github/callback

# ============================================
# Authorized Users
# ============================================
# Comma-separated list of GitHub usernames allowed to access admin
AUTHORIZED_GITHUB_USERS=dhruvlagad

# ============================================
# Session Configuration
# ============================================
# Generate a strong random string (minimum 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_strong_random_secret_key_here_min_32_chars

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=production

# Optional: Custom frontend URL (leave blank for GitHub Pages default)
# FRONTEND_URL=https://dhruvlagad.github.io

# ============================================
# Production Deployment Notes
# ============================================
# When deploying to Render.com:
# 1. Set NODE_ENV=production
# 2. Update GITHUB_CALLBACK_URL to your Render app URL
# 3. Update GitHub OAuth app settings with Render callback URL
# 4. Use a strong SESSION_SECRET generated with the command above
# 5. Deploy and test auth flow
