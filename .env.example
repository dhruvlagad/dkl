# GitHub OAuth Configuration
# Create a GitHub OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Authorized GitHub usernames (comma-separated)
# Only these users will be able to access the admin panel
AUTHORIZED_GITHUB_USERS=dhruvlagad,kiranlagad

# Session Secret (generate a random string)
SESSION_SECRET=dhruvlagad-32-characters-secret.

# Server Configuration
PORT=3000
NODE_ENV=development

# Production Configuration (when deploying)
# For GitHub Pages: GITHUB_CALLBACK_URL=https://dhruvlagad.github.io/dkl/auth/github/callback
# For custom domain: GITHUB_CALLBACK_URL=https://yourdomain.com/auth/github/callback
# NODE_ENV=production
# Important: Register the callback URL in GitHub OAuth app settings at: https://github.com/settings/developers

